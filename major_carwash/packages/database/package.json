{
  "name": "@repo/database",
  "author": "Joseph Adogeri",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prebuild": "node -e \"try { require('fs').unlinkSync('tsconfig.tsbuildinfo') } catch (e) {}\"",
    "build": "tsc",
    "dev": "tsc --watch",
    "db:debug": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm debug --config src/mikro-orm.config.ts",
    "db:create": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm migration:create --config src/mikro-orm.config.ts",
    "db:up": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm migration:up --config src/mikro-orm.config.ts",
    "db:down": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm migration:down --config src/mikro-orm.config.ts",
    "db:fresh": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm migration:fresh --config src/mikro-orm.config.ts",
    "db:sync": "cross-env MIKRO_ORM_CLI_PREFER_TS=true mikro-orm schema:update --reschema --config src/mikro-orm.config.ts"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@mikro-orm/core": "^7.0.15",
    "@mikro-orm/decorators": "^7.0.15",
    "@mikro-orm/libsql": "^7.0.15",
    "@mikro-orm/reflection": "^7.0.15",
    "better-auth": "^1.6.11",
    "better-auth-mikro-orm": "^0.5.0",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^7.0.15",
    "@mikro-orm/migrations": "^7.0.15",
    "tsx": "^4.21.0"
  }
}
